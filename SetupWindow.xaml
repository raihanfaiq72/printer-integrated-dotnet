<Window x:Class="marker_dotnet.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:marker_dotnet"
        mc:Ignorable="d"
        Title="Setup - Marker Crystal"
        Height="700"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"
        ResizeMode="CanResize">

    <Window.Resources>

        <!-- Primary Button -->
        <Style x:Key="Win11Button" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="Win11SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- TextBox -->
        <Style x:Key="Win11TextBox" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- PasswordBox -->
        <Style x:Key="Win11PasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White" Height="70">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0">
                <Border Background="#0078D4" CornerRadius="8" Width="36" Height="36" Margin="0,0,16,0">
                    <TextBlock Text="⚙️" FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"/>
                </Border>

                <StackPanel>
                    <TextBlock Text="Setup Marker Crystal"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#323130"/>
                    <TextBlock Text="Configure your application settings"
                               FontSize="12"
                               Foreground="#605E5C"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- FORM -->
        <Border Grid.Row="1" Background="White" Margin="30,20" CornerRadius="8">
            <Grid Margin="40">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Description -->
                <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                           Text="This is the first time setup. Please configure your application:"
                           Margin="0,0,0,30"
                           FontSize="14"/>

                <!-- Program Name -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Program name"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="ProgramNameTextBox"
                         Grid.Row="1" Grid.Column="1"
                         Style="{StaticResource Win11TextBox}"
                         Text="Printer marker"/>

                <!-- Printer -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Printer name"
                           Margin="0,20,0,0"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="PrinterNameTextBox"
                         Grid.Row="2" Grid.Column="1"
                         Style="{StaticResource Win11TextBox}"
                         Margin="0,20,0,0"
                         Text="EPSON TM-U220B"/>

                <!-- Password -->
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="Installation password"
                           Margin="0,20,0,0"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,20,0,0">
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource Win11PasswordBox}"/>
                    <TextBlock Text="Contact administrator for password"
                               FontSize="11"
                               Foreground="#605E5C"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Error -->
                <Border Grid.Row="4" Grid.ColumnSpan="2"
                        x:Name="ErrorBorder"
                        Background="#FDE7E9"
                        CornerRadius="6"
                        Padding="16"
                        Margin="0,20,0,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorMessage"
                               Foreground="#A4262C"/>
                </Border>

            </Grid>
        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="White" Height="80">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="30,0">

                <Button Content="Cancel"
                        Style="{StaticResource Win11SecondaryButton}"
                        Margin="0,0,16,0"
                        Click="CancelButton_Click"/>

                <Button Content="Save configuration"
                        Style="{StaticResource Win11Button}"
                        Click="SaveButton_Click"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>